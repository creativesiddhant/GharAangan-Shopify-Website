{%- comment -%}
  Renders a free shipping bar

  Accepts:
  - shipping_amount: {Number} Free shipping amount (required)

  Usage:
  {%- render 'cart-shipping-bar', shipping_amount: shipping_amount -%}
{%- endcomment -%}

{%- liquid
  assign shipping_style_1 = true 
  assign shipping_style_2 = false

  assign shipping_standard_amount = settings.free_ship_pr.metafields.theme.shipping_money.value | default: settings.free_ship_pr.price | default: -1
  assign shipping_fast_amount = settings.free_ship_pr_fast.metafields.theme.shipping_money.value | default: settings.free_ship_pr_fast.price | default: -1
  assign shipping_express_amount = settings.free_ship_pr_express.metafields.theme.shipping_money.value | default: settings.free_ship_pr_express.price | default: -1

  assign gift_product = settings.free_ship_pr_fast.metafields.theme.get_gift.value

  # Choose the highest shipping amount
 
  if shipping_standard_amount > 0 and shipping_standard_amount > shipping_fast_amount and shipping_standard_amount > shipping_express_amount
    assign shipping_amount = shipping_standard_amount
  elsif shipping_fast_amount > 0 and shipping_fast_amount > shipping_express_amount
    assign shipping_amount = shipping_fast_amount
  elsif shipping_express_amount > 0
    assign shipping_amount = shipping_express_amount
  endif
  # End of Choose the highest shipping amount
  
  # check milestone progress
  assign gift_card_id = gift_product.id

  assign calculated_total_price = 0

  # If the item is not a gift card or not discount product, add the price to the calculated total price

  assign shipping_protection = settings.protect_product
  assign shipping_protection_id = shipping_protection.selected_or_first_available_variant.id | default: shipping_protection.variants.first.id | default: shipping_protection.id
  assign cart_items = cart.items | reject: 'variant_id', shipping_protection_id | default: cart.items
  
  for item in cart_items
    if item.requires_shipping and item.variant_id != gift_card_id
      assign calculated_total_price = calculated_total_price | plus: item.original_line_price
    endif
  endfor
  #assign calculated_total_price = cart.items | where: "requires_shipping", true | sum: 'original_line_price'

  assign progress_shipping = calculated_total_price | times: 1.0 | divided_by: shipping_amount | at_most: 1

  assign standard_pos = shipping_standard_amount | times: 1.0 | divided_by: shipping_amount | at_most: 1
  assign fast_pos = shipping_fast_amount | times: 1.0 | divided_by: shipping_amount | at_most: 1
  assign express_pos = shipping_express_amount | times: 1.0 | divided_by: shipping_amount | at_most: 1

  # check milestone progress
  if progress_shipping < standard_pos 
    assign shipping_amount_milestone = shipping_standard_amount
  elsif progress_shipping < fast_pos
    assign shipping_amount_milestone = shipping_fast_amount
  elsif progress_shipping < express_pos
    assign shipping_amount_milestone = shipping_express_amount
  endif

  # end check milestone progress

  if settings.currency_code_enabled
    assign money_need_add = shipping_amount_milestone | minus: calculated_total_price | money_with_currency
  else
    assign money_need_add = shipping_amount_milestone | minus: calculated_total_price | money
  endif

  # Caculator milestones

  assign show_fast = false 
  assign show_express = false 

  if shipping_fast_amount > shipping_standard_amount
    assign show_fast = true
    assign shipping_style_1 = false
    assign shipping_style_2 = true
  endif
  if shipping_express_amount > shipping_fast_amount and shipping_express_amount > shipping_standard_amount
    assign show_express = true
    assign shipping_style_1 = false
    assign shipping_style_2 = true
  endif

  # End of Caculator milestones

  assign standard_success = ''
  assign fast_success = ''
  assign express_success = ''

-%}

{%- capture shipping_message -%}
  {%- if shipping_style_1 -%}
    {%- if progress_shipping == 0 -%}
      {{ 'sections.cart.free_shipping_bar.intial_html' | t: money: money_need_add }}
    {%- elsif progress_shipping == 1 -%}
      {{ 'sections.cart.free_shipping_bar.success' | t | replace: '[', '<span class="is--congratulations">' | replace: ']', '</span>'  }}
    {%- else -%}
      {{ 'sections.cart.free_shipping_bar.unreached_html' | t: money: money_need_add }}
    {%- endif -%} 
  {%- else -%}
    {%- if progress_shipping == 0 -%}
      {{ 'sections.cart.free_shipping_bar.intial_html' | t: money: money_need_add }}
    {%- elsif progress_shipping < standard_pos -%}
      {{ 'sections.cart.free_shipping_bar_2.milestone_1_html' | t: money: money_need_add }}
    {%- elsif progress_shipping < fast_pos -%}
      {% assign standard_success = ' is-success' %}
      {{ 'sections.cart.free_shipping_bar_2.milestone_2_html' | t: money: money_need_add }}
    {%- elsif progress_shipping < express_pos -%}
      {% assign standard_success = ' is-success' %}
      {% assign fast_success = ' is-success' %}
      {{ 'sections.cart.free_shipping_bar_2.milestone_3_html' | t: money: money_need_add }}
    {%- else -%}
      {% assign standard_success = ' is-success' %}
      {% assign fast_success = ' is-success' %}
      {% assign express_success = ' is-success' %}
      {{ 'sections.cart.free_shipping_bar_2.success' | t | replace: '[', '<span class="is--congratulations">' | replace: ']', '</span>'  }}
    {%- endif -%}
  {%- endif -%}
{%- endcapture -%}

<hdt-free-shipping-bar class="hdt-free-shipping-bar is-{% if progress_shipping <= 0.7 %}intial{% elsif progress_shipping == 1 %}success{% else %}unreached{% endif %}">
