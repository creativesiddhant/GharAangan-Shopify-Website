<!-- snippets/page-our-story-custom.liquid -->
<div class="ga-story-page-wrapper" style="padding: 2rem 0;">
  
  <!-- Hero Section -->
  <div class="ga-story-hero" style="background: linear-gradient(rgba(26, 51, 44, 0.9), rgba(26, 51, 44, 0.9)), url('{{ 'ghar-aangan-hero-banner.jpg' | asset_url }}') no-repeat center center; background-size: cover; padding: 10rem 2rem; text-align: center; border-radius: 16px; margin-bottom: 6rem; border: 1px solid var(--ga-border-color); box-shadow: var(--ga-card-shadow);">
    <div style="max-width: 800px; margin: 0 auto;">
      <span class="ga-subtitle" style="color: var(--ga-gold-cream); font-size: 1.4rem; letter-spacing: 0.25em;">OUR ROOTS & VALUES</span>
      <h1 class="ga-title" style="color: #ffffff; font-size: clamp(3.2rem, 6vw, 5.2rem); margin-top: 1.5rem; margin-bottom: 2.5rem; line-height: 1.2; font-family: var(--ga-font-family-serif);">Crafted with Intent, Churned with Tradition</h1>
      <p class="ga-body" style="color: rgba(255, 255, 255, 0.85); font-size: 1.7rem; line-height: 1.7; font-weight: 300;">
        Ghar Aangan was born from a simple desire: to reconnect modern homes with pure, unadulterated nourishment. Having grown up in the crisp mountain air of Uttarakhand, our founder set out to preserve and share the traditional Bilona method of ghee making directly from small farming collectives.
      </p>
    </div>
  </div>

  <!-- The Journey Section (Split) -->
  <style>
    .ga-journey-split {
      display: grid;
      grid-template-columns: 1fr;
      gap: 4rem;
      align-items: center;
      margin-bottom: 8rem;
      padding: 0 1.5rem;
    }
    @media screen and (min-width: 750px) {
      .ga-journey-split {
        grid-template-columns: 1fr 1.2fr;
        gap: 6rem;
      }
    }
  </style>

  <div class="ga-journey-split">
    <!-- Left Arched Image -->
    <div style="text-align: center;">
      <div class="ga-arch-container ga-reveal" style="max-width: 100%;">
        <img class="ga-arch-top" src="{{ 'ghar-aangan-lifestyle.jpg' | asset_url }}" alt="Ghar Aangan Founder's Story" style="width: 100%; max-width: 400px; height: auto; display: block;" loading="lazy">
      </div>
    </div>
    <!-- Right Text -->
    <div class="ga-reveal">
      <span class="ga-subtitle">THE FOUNDER'S JOURNEY</span>
      <h2 class="ga-title" style="font-size: clamp(2.4rem, 4vw, 3.4rem); margin-top: 1rem; margin-bottom: 2rem;">Back to the Soil</h2>
      <p class="ga-body" style="font-size: 1.55rem; line-height: 1.7; color: var(--ga-dark-text); font-weight: 300; margin-bottom: 2rem;">
        Having grown up in the pristine valleys of Uttarakhand, our founder witnessed the steady industrialization of food production, resulting in the loss of traditional nutritional methods. Standard ghee in stores became heavily processed, separated from cream by high-speed motors, and stripped of its Vedic properties.
      </p>
      <p class="ga-body" style="font-size: 1.55rem; line-height: 1.7; color: var(--ga-dark-text); font-weight: 300;">
        Determined to preserve ancestral knowledge, they returned to rural farming communities in Uttarakhand. Collaborating with small local households and self-help women's collectives, they established a fair-trade supply network, giving birth to Ghar Aangan: the essence of the high Himalayas delivered directly to your doorstep.
      </p>
    </div>
  </div>

  <!-- The Terroir Section (Reverse Split) -->
  <div class="ga-journey-split" style="direction: ltr;">
    <style>
      @media screen and (min-width: 750px) {
        .ga-journey-split-reverse {
          grid-template-columns: 1.2fr 1fr;
        }
        .ga-journey-split-reverse .ga-right-col {
          order: 2;
        }
        .ga-journey-split-reverse .ga-left-col {
          order: 1;
        }
      }
    </style>
    <div class="ga-journey-split-reverse" style="display: grid; gap: 4rem; align-items: center; width: 100%;">
      <!-- Left Text -->
      <div class="ga-left-col ga-reveal" style="text-align: left;">
        <span class="ga-subtitle">HIMALAYAN HERITAGE</span>
        <h2 class="ga-title" style="font-size: clamp(2.4rem, 4vw, 3.4rem); margin-top: 1rem; margin-bottom: 2rem;">Purity from the High Altitudes</h2>
        <p class="ga-body" style="font-size: 1.55rem; line-height: 1.7; color: var(--ga-dark-text); font-weight: 300; margin-bottom: 2rem;">
          Our ghee originates in the pristine valleys of Uttarakhand, where native Badri cows graze on wild medicinal herbs and fresh mountain flora. This natural diet renders a golden, granular ghee rich in vitamins, minerals, and deep organic aroma, untouched by modern industrialized processing.
        </p>
        <p class="ga-body" style="font-size: 1.55rem; line-height: 1.7; color: var(--ga-dark-text); font-weight: 300;">
          The altitude, clean mountain streams, and uncontaminated soil give the herbs dynamic medicinal potency. The milk gathered here is packed with fat-soluble vitamins (A, D, E, K), CLA, and rich butyric acid structures that promote immune and digestive wellness.
        </p>
      </div>
      <!-- Right Arched Image -->
      <div class="ga-right-col ga-reveal" style="text-align: center;">
        <div class="ga-arch-container">
          <img class="ga-arch-top" src="{{ 'ghar-aangan-product-ghee.jpg' | asset_url }}" alt="High Altitude Badri cows ghee" style="width: 100%; max-width: 400px; height: auto; display: block;" loading="lazy">
        </div>
      </div>
    </div>
  </div>

  <!-- Commitments / Core Values -->
  <div style="margin-bottom: 8rem; margin-top: 4rem;">
    <div class="ga-section-header" style="margin-bottom: 5rem;">
      <span class="ga-subtitle">OUR VALUES</span>
      <h2 class="ga-title">The Ghar Aangan Promise</h2>
    </div>

    <style>
      .ga-promise-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
        padding: 0 1.5rem;
      }
      @media screen and (min-width: 750px) {
        .ga-promise-grid {
          grid-template-columns: repeat(3, 1fr);
        }
      }
    </style>

    <div class="ga-promise-grid">
      
      <!-- Card 1 -->
      <div class="ga-inset-border ga-corner-stars ga-reveal" style="background: #ffffff; padding: 4.5rem 3rem; text-align: center;">
        <div class="ga-corner-stars-inner"></div>
        <h3 class="ga-title" style="font-size: 2.2rem; margin-bottom: 1.5rem;">Vedic Integrity</h3>
        <p class="ga-body" style="font-size: 1.45rem; line-height: 1.6; color: var(--ga-dark-text); margin: 0; font-weight: 300;">
          We pledge to churn our ghee using the traditional Bilona method from curd starter, never cream. We simmer slowly on firewood in earthen pots, strictly preserving Vedic principles.
        </p>
      </div>

      <!-- Card 2 -->
      <div class="ga-inset-border ga-corner-stars ga-reveal" style="background: #ffffff; padding: 4.5rem 3rem; text-align: center;">
        <div class="ga-corner-stars-inner"></div>
        <h3 class="ga-title" style="font-size: 2.2rem; margin-bottom: 1.5rem;">Rural Empowerment</h3>
        <p class="ga-body" style="font-size: 1.45rem; line-height: 1.6; color: var(--ga-dark-text); margin: 0; font-weight: 300;">
          We support small hill farming families, ensuring sustainable fair-trade livelihoods for women's collectives, helping protect native rural structures and economic survival.
        </p>
      </div>

      <!-- Card 3 -->
      <div class="ga-inset-border ga-corner-stars ga-reveal" style="background: #ffffff; padding: 4.5rem 3rem; text-align: center;">
        <div class="ga-corner-stars-inner"></div>
        <h3 class="ga-title" style="font-size: 2.2rem; margin-bottom: 1.5rem;">Radical Purity</h3>
        <p class="ga-body" style="font-size: 1.45rem; line-height: 1.6; color: var(--ga-dark-text); margin: 0; font-weight: 300;">
          Radical transparency. Zero chemicals, preservatives, coloring, palm oil, or adulterants. Every batch undergoes third-party lab inspection before reaching your table.
        </p>
      </div>

    </div>
  </div>

  <!-- Call to Action -->
  <div style="background-color: var(--ga-forest-green); border-radius: 16px; padding: 6rem 3rem; text-align: center; border: 1.5px solid var(--ga-gold-cream); box-shadow: var(--ga-card-shadow);">
    <div style="max-width: 600px; margin: 0 auto;">
      <span class="ga-subtitle" style="color: var(--ga-gold-cream); display: block; margin-bottom: 1.5rem;">EXPERIENCE HIMALAYAN NOURISHMENT</span>
      <h2 class="ga-title" style="color: #ffffff; font-size: clamp(2.4rem, 4vw, 3.4rem); margin-bottom: 2rem;">Pure A2 Ghee Churned For You</h2>
      <p class="ga-body" style="color: rgba(255, 255, 255, 0.8); font-size: 1.5rem; line-height: 1.6; margin-bottom: 3.5rem;">
        Enjoy the golden granular texture, the smoky firewood aroma, and the unmatched nutritional value of high altitude Vedic Bilona Ghee.
      </p>
      <a href="/collections/all" class="ga-btn-primary" style="background-color: #ffffff; color: var(--ga-forest-green) !important; border-color: #ffffff;">
        Shop Our Collection
      </a>
      <style>
        .ga-btn-primary[style*="background-color: #ffffff"]::before {
          background-color: var(--ga-gold-cream);
        }
        .ga-btn-primary[style*="background-color: #ffffff"]:hover {
          color: #ffffff !important;
          border-color: var(--ga-gold-cream);
        }
      </style>
    </div>
  </div>

</div>
