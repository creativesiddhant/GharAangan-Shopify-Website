                      <span class="hdt-menu-link-text hdt-flex hdt-align-center hdt-justify-center {% if arr_label.size > 0 %} hdt-relative hdt-title_size-{{ arr_title[0].size | at_most: 20 }} hdt-has-{{ arr_label.size | at_most: 2 }}label{% endif %}">
                        {%- if cat_img != null -%}
                        <span class="hdt-category-img hdt-relative">
                            {{ cat_img | image_url: width: cat_img.width | image_tag: loading: 'lazy', class: 'hdt-radius-full', widths: '50,100,150,200,250,300,350', style: 'object-fit:cover;width: 34px' }}
                          </span>
                        {%- endif -%}
                        <span class="hdt-block hdt-line-clamp">{{ arr_title[0] }}</span>
                        {%- if arr_label.size > 0 -%}
                          <span class="hdt_label_menu hdt-absolute hdt-inline-flex hdt-align-center hdt-justify-center hdt-text-xs hdt-font-medium">
                            {%- for label in arr_label limit: 2 -%}
                              {%- assign label_text = label | remove: 'label_' | remove: ','  | remove: ']' | strip -%}
                              <span class="hdt_label_{{ label_text | handleize }} hdt-flex hdt-align-center hdt-justify-center">{{ label_text }}</span>
                            {%- endfor -%}
                          </span>
                        {%- endif -%}
                      </span>
                    </a>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        </div>
