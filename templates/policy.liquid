<!-- templates/policy.liquid -->
{%- if policy.title == 'Refund policy' or policy.title == 'Refund Policy' or request.path contains 'refund-policy' -%}
  {%- render 'page-refund-policy-custom' -%}
{%- else -%}
  <!-- Default Policy Layout for other pages (Privacy, Terms, etc.) -->
  <style>
    .hdt-section-heading {
      display: none !important;
    }
  </style>
  <div class="ga-shipping-page-wrapper" style="padding: 4rem 1.5rem; font-family: var(--ga-font-family-sans); max-width: 750px; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 5rem; border-bottom: 1.5px solid var(--ga-border-color); padding-bottom: 4rem;">
      <h1 class="ga-title" style="font-family: var(--ga-font-family-serif); font-size: clamp(3rem, 5vw, 4.4rem); color: var(--ga-forest-green); margin-top: 1rem;">{{ policy.title }}</h1>
    </div>
    <div class="ga-body hdt-rte" style="font-size: 1.55rem; line-height: 1.7; color: var(--ga-dark-text); font-weight: 300;">
      {{ policy.body }}
    </div>
  </div>
{%- endif -%}
