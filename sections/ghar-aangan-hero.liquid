{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding" style="background-color: transparent;">
  <div class="ga-hero-grid-container">
    
    <!-- Left Main Banner (Large Card) -->
    <div class="ga-hero-left-banner ga-reveal">
      {%- if section.settings.image != blank -%}
        <picture>
          {%- if section.settings.image_mobile != blank -%}
            <source media="(max-width: 749px)" srcset="{{ section.settings.image_mobile | image_url: width: 750 }}">
          {%- endif -%}
          <img
            class="ga-hero-left-img"
            src="{{ section.settings.image | image_url: width: 1200 }}"
            alt="{{ section.settings.title | escape }}"
            loading="eager"
            width="1200"
            height="650"
          >
        </picture>
      {%- else -%}
        <img
          class="ga-hero-left-img"
          src="{{ 'ghar-aangan-hero-banner.jpg' | asset_url }}"
          alt="Ghar Aangan Premium A2 Ghee Hero Banner"
          loading="eager"
          width="1200"
          height="650"
        >
      {%- endif -%}
      <div class="ga-hero-left-overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
      
      <!-- Announcement Card Overlay -->
      <div class="ga-hero-left-card">
        {%- if section.settings.subtitle != blank -%}
          <span class="ga-subtitle">{{ section.settings.subtitle | escape }}</span>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="ga-title">{{ section.settings.title | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="ga-body">{{ section.settings.description | escape }}</p>
        {%- endif -%}
        {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
          <a href="{{ section.settings.button_link }}" class="ga-btn-primary">
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>

    <!-- Right Stacked Banners -->
    <div class="ga-hero-right-column">
      
      <!-- Right Top Card -->
      <a href="{{ section.settings.right_top_link | default: '#' }}" class="ga-hero-subcard ga-reveal" style="background: {{ section.settings.right_top_bg_color | default: '#fcf6e8' }};">
        <div class="ga-hero-subcard-content">
          {%- if section.settings.right_top_subtitle != blank -%}
            <span class="ga-hero-subcard-subtitle">{{ section.settings.right_top_subtitle | escape }}</span>
          {%- endif -%}
          <h3 class="ga-hero-subcard-title">{{ section.settings.right_top_title | default: 'A2 Bilona Badri Ghee' | escape }}</h3>
          <span class="ga-hero-subcard-btn">
            Shop Now
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </span>
        </div>
        <div class="ga-hero-subcard-img-wrap">
          {%- if section.settings.right_top_image != blank -%}
            <img class="ga-hero-subcard-img" src="{{ section.settings.right_top_image | image_url: width: 300 }}" alt="{{ section.settings.right_top_title | escape }}" loading="eager" width="150" height="150">
          {%- else -%}
            <img class="ga-hero-subcard-img" src="{{ 'ghar-aangan-product-ghee.jpg' | asset_url }}" alt="Ghar Aangan A2 Bilona Ghee" loading="eager" width="150" height="150">
          {%- endif -%}
        </div>
      </a>

      <!-- Right Bottom Card -->
      <a href="{{ section.settings.right_bottom_link | default: '#' }}" class="ga-hero-subcard ga-reveal" style="background: {{ section.settings.right_bottom_bg_color | default: '#f4ece1' }};">
        <div class="ga-hero-subcard-content">
          {%- if section.settings.right_bottom_subtitle != blank -%}
            <span class="ga-hero-subcard-subtitle">{{ section.settings.right_bottom_subtitle | escape }}</span>
          {%- endif -%}
          <h3 class="ga-hero-subcard-title">{{ section.settings.right_bottom_title | default: 'Himalayan Organic Ghee' | escape }}</h3>
          <span class="ga-hero-subcard-btn">
            Shop Now
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </span>
        </div>
        <div class="ga-hero-subcard-img-wrap">
          {%- if section.settings.right_bottom_image != blank -%}
            <img class="ga-hero-subcard-img" src="{{ section.settings.right_bottom_image | image_url: width: 300 }}" alt="{{ section.settings.right_bottom_title | escape }}" loading="eager" width="150" height="150">
          {%- else -%}
            <img class="ga-hero-subcard-img" src="{{ 'ghar-aangan-product-ghee.jpg' | asset_url }}" alt="Ghar Aangan A2 Bilona Ghee" loading="eager" width="150" height="150">
          {%- endif -%}
        </div>
      </a>

    </div>

  </div>
</div>

{% schema %}
{
  "name": "GA Premium Hero Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Left Main Card Settings"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop Background Image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile Background Image (Optional)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "Background Overlay Opacity",
      "default": 30
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle Tag",
      "default": "PURE HIMALAYAN BILONA GHEE"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Main Title",
      "default": "Ghar Aangan: The Essence of Uttarakhand"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description Text",
      "default": "Handcrafted in the Himalayas, our A2 ghee is churned using traditional Bilona methods to deliver unmatched purity, taste, and nutrition to your home."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Himalayan Purity"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Right Top Card Settings"
    },
    {
      "type": "text",
      "id": "right_top_title",
      "label": "Top Card Title",
      "default": "A2 Bilona Badri Ghee"
    },
    {
      "type": "text",
      "id": "right_top_subtitle",
      "label": "Top Card Subtitle",
      "default": "ORGANIC HIGHLANDS"
    },
    {
      "type": "url",
      "id": "right_top_link",
      "label": "Top Card Link"
    },
    {
      "type": "image_picker",
      "id": "right_top_image",
      "label": "Top Card Product Image"
    },
    {
      "type": "color",
      "id": "right_top_bg_color",
      "label": "Top Card Background Color",
      "default": "#fcf6e8"
    },
    {
      "type": "header",
      "content": "Right Bottom Card Settings"
    },
    {
      "type": "text",
      "id": "right_bottom_title",
      "label": "Bottom Card Title",
      "default": "Himalayan Organic Honey"
    },
    {
      "type": "text",
      "id": "right_bottom_subtitle",
      "label": "Bottom Card Subtitle",
      "default": "100% PURE & RAW"
    },
    {
      "type": "url",
      "id": "right_bottom_link",
      "label": "Bottom Card Link"
    },
    {
      "type": "image_picker",
      "id": "right_bottom_image",
      "label": "Bottom Card Product Image"
    },
    {
      "type": "color",
      "id": "right_bottom_bg_color",
      "label": "Bottom Card Background Color",
      "default": "#f4ece1"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "GA Premium Hero Grid"
    }
  ]
}
{% endschema %}
