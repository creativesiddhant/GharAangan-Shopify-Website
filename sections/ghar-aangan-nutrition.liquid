{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .ga-nutrition-section {
    background-color: {{ section.settings.background_color }};
  }

  .ga-nutrition-split {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: start;
  }

  @media screen and (min-width: 750px) {
    .ga-nutrition-split {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 6rem;
    }
  }

  /* Classical Nutrition Label Styling */
  .ga-nutrition-label {
    background: #ffffff;
    border: 1px solid var(--ga-forest-green);
    outline: 1px solid var(--ga-gold-cream);
    outline-offset: -6px;
    padding: 4.5rem 4rem;
    font-family: var(--ga-font-family-sans);
    color: var(--ga-dark-text);
    border-radius: 8px;
    box-shadow: var(--ga-card-shadow);
  }

  @media screen and (max-width: 749px) {
    .ga-nutrition-label {
      padding: 3rem 2.5rem;
    }
  }

  .ga-nutrition-label-title {
    font-family: var(--ga-font-family-serif);
    font-size: clamp(2.4rem, 4vw, 3rem);
    font-weight: 600;
    margin: 0;
    color: var(--ga-forest-green);
    border-bottom: 6px solid var(--ga-forest-green);
    padding-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .ga-nutrition-serving {
    font-size: 1.4rem;
    margin: 0.8rem 0;
    font-weight: 500;
    border-bottom: 1px solid var(--ga-dark-text);
    padding-bottom: 0.8rem;
  }

  .ga-nutrition-amount-title {
    font-size: 1.2rem;
    font-weight: 700;
    margin: 0.6rem 0;
  }

  .ga-nutrition-row-header {
    border-bottom: 3px solid var(--ga-dark-text);
    display: flex;
    justify-content: space-between;
    font-weight: 700;
    font-size: 1.3rem;
    padding-bottom: 0.3rem;
  }

  .ga-nutrition-item {
    display: flex;
    justify-content: space-between;
    padding: 0.9rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.12);
    font-size: 1.4rem;
  }

  .ga-nutrition-item.indent {
    padding-left: 2rem;
    font-size: 1.3rem;
    color: rgba(0, 0, 0, 0.65);
  }

  .ga-nutrition-item.bold-name .name {
    font-weight: 700;
  }

  /* Right column: Certification Card */
  .ga-cert-card {
    background-color: var(--ga-light-bg);
    border: 1px solid var(--ga-border-color);
    border-radius: 8px;
    padding: 4.5rem 4rem;
    box-shadow: var(--ga-card-shadow);
    transition: var(--ga-transition-smooth);
  }

  .ga-cert-card:hover {
    border-color: var(--ga-gold-cream);
    transform: translateY(-4px);
  }

  @media screen and (max-width: 749px) {
    .ga-cert-card {
      padding: 3rem 2.5rem;
    }
  }

  .ga-cert-badge-row {
    display: flex;
    gap: 1.8rem;
    margin: 2.8rem 0;
    align-items: center;
  }

  .ga-cert-badge-icon {
    width: 4rem;
    height: 4rem;
    color: var(--ga-himalayan-emerald);
    flex-shrink: 0;
  }

  .ga-cert-badge-text {
    font-family: var(--ga-font-family-sans);
    font-size: 1.45rem;
    line-height: 1.5;
    font-weight: 300;
  }

  .ga-cert-image-wrap {
    margin: 3.5rem 0;
    border: 1px solid var(--ga-border-color);
    border-radius: 8px;
    overflow: hidden;
    background: #ffffff;
    padding: 2rem;
    text-align: center;
    box-shadow: 0 10px 25px rgba(26, 51, 44, 0.03);
  }

  .ga-cert-image {
    max-width: 100%;
    height: auto;
    object-fit: contain;
    max-height: 250px;
    transition: var(--ga-transition-smooth);
  }

  .ga-cert-card:hover .ga-cert-image {
    transform: scale(1.03);
  }
{%- endstyle -%}

<div class="ga-nutrition-section section-{{ section.id }}-padding">
  <div class="page-width">
    {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
      <div class="ga-section-header ga-reveal">
        {%- if section.settings.subtitle != blank -%}
          <span class="ga-subtitle">{{ section.settings.subtitle | escape }}</span>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="ga-title" style="margin-top: 1rem;">{{ section.settings.title | escape }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="ga-nutrition-split">
      <!-- Left Column: Nutrition Facts -->
      <div class="ga-nutrition-label ga-reveal">
        <h3 class="ga-nutrition-label-title">Nutrition Facts</h3>
        <div class="ga-nutrition-serving">
          Serving Size: 1 Tbsp (15ml)<br>
          Servings Per Container: {% if product.variants.first.title contains '250' %}17{% elsif product.variants.first.title contains '500' %}33{% else %}66{% endif %}
        </div>
        <div class="ga-nutrition-row-header">
          <span>Amount Per Serving</span>
          <span>% Daily Value*</span>
        </div>
        
        <div class="ga-nutrition-item bold-name">
          <span class="name">Calories</span>
          <span class="value">135 kcal</span>
        </div>
        
        <div class="ga-nutrition-item bold-name">
          <span class="name">Total Fat 15g</span>
          <span class="value">23%</span>
        </div>
        <div class="ga-nutrition-item indent">
          <span class="name">Saturated Fat 9.8g</span>
          <span class="value">49%</span>
        </div>
        <div class="ga-nutrition-item indent">
          <span class="name">Monounsaturated Fat 4.4g</span>
          <span class="value">-</span>
        </div>
        <div class="ga-nutrition-item indent">
          <span class="name">Polyunsaturated Fat 0.6g</span>
          <span class="value">-</span>
        </div>
        
        <div class="ga-nutrition-item bold-name">
          <span class="name">Cholesterol 38mg</span>
          <span class="value">13%</span>
        </div>
        
        <div class="ga-nutrition-item bold-name">
          <span class="name">Sodium 0mg</span>
          <span class="value">0%</span>
        </div>
        
        <div class="ga-nutrition-item bold-name">
          <span class="name">Total Carbohydrate 0g</span>
          <span class="value">0%</span>
        </div>
        
        <div class="ga-nutrition-item bold-name">
          <span class="name">Protein 0g</span>
          <span class="value">0%</span>
        </div>
        
        <div class="ga-nutrition-item">
          <span class="name">Vitamin A (Beta Carotene)</span>
          <span class="value">10%</span>
        </div>
        <div class="ga-nutrition-item">
          <span class="name">Vitamin E</span>
          <span class="value">4%</span>
        </div>
        
        <div style="font-size: 1.1rem; margin-top: 1.5rem; font-weight: 300; line-height: 1.4; border-top: 3px solid var(--ga-dark-text); padding-top: 0.8rem;">
          * The % Daily Value (DV) tells you how much a nutrient in a serving of food contributes to a daily diet. 2,000 calories a day is used for general nutrition advice.
        </div>
      </div>

      <!-- Right Column: Lab Certification Details -->
      <div class="ga-cert-card ga-reveal">
        <span class="ga-subtitle">{{ section.settings.cert_subtitle | escape }}</span>
        <h3 class="ga-title" style="margin-top: 1rem; margin-bottom: 2rem;">{{ section.settings.cert_title | escape }}</h3>
        <p class="ga-body" style="font-size: 1.5rem;">{{ section.settings.cert_description }}</p>

        <div class="ga-cert-badge-row">
          <svg class="ga-cert-badge-icon" viewBox="0 0 24 24">
            <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
          </svg>
          <div class="ga-cert-badge-text ga-body">
            <strong>Zero Starch & Heavy Metals:</strong> Certified clean by national laboratory safety analysis.
          </div>
        </div>

        {%- if section.settings.cert_image != blank -%}
          <div class="ga-cert-image-wrap">
            <img class="ga-cert-image" src="{{ section.settings.cert_image | image_url: width: 400 }}" alt="Lab Certification report snippet" loading="lazy" width="250" height="250">
          </div>
        {%- endif -%}

        {%- if section.settings.download_url != blank -%}
          <a href="{{ section.settings.download_url }}" class="ga-btn-secondary" style="width: 100%; text-align: center; justify-content: center; box-sizing: border-box;">
            {{ section.settings.download_label | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "GA Nutrition & Certs",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Section Subtitle",
      "default": "PURITY & ANALYSIS"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Nutritional Value & Certifications"
    },
    {
      "type": "header",
      "content": "Lab Certificate Settings"
    },
    {
      "type": "text",
      "id": "cert_subtitle",
      "label": "Cert Card Subtitle",
      "default": "100% TRANSPARENT"
    },
    {
      "type": "text",
      "id": "cert_title",
      "label": "Cert Card Title",
      "default": "Download Lab Test Certificate"
    },
    {
      "type": "textarea",
      "id": "cert_description",
      "label": "Cert Description",
      "default": "We believe in radical transparency. Every batch of our A2 Bilona Ghee undergoes rigorous third-party laboratory analysis to guarantee full purity, zero adulteration, and optimal moisture values."
    },
    {
      "type": "image_picker",
      "id": "cert_image",
      "label": "Certificate Snippet Image",
      "info": "Recommended: 600x800px (Portrait) or 600x600px (Square)"
    },
    {
      "type": "text",
      "id": "download_label",
      "label": "Download Button Label",
      "default": "View Lab Report (PDF)"
    },
    {
      "type": "url",
      "id": "download_url",
      "label": "Download URL"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "GA Nutrition & Certs"
    }
  ]
}
{% endschema %}
